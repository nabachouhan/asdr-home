<%- include("../partials/userHeader") %>

    <body>
        <%- include("../partials/loader") %>
            <%- include("../partials/arrownav") %>

                <div class="sdr-auth-wrapper">
                    <div class="sdr-auth-card">
                        <!-- Tabs -->
                        <div class="sdr-auth-tabs">
                            <a href="/user" class="sdr-auth-tab">Register</a>
                            <a href="/user/Login" class="sdr-auth-tab">Login</a>
                            <a href="/user/Forgot" class="sdr-auth-tab active">Update</a>
                        </div>

                        <!-- Form Body -->
                        <div class="sdr-auth-body">
                            <form id="forgotForm" action="/user/forgot" method="POST" enctype="multipart/form-data">

                                <!-- Email + Get OTP + Enter OTP -->
                                <div class="form-row-auth" style="grid-template-columns: 2fr 1fr 2fr;">
                                    <div class="form-group-auth">
                                        <label for="email">E-mail Address <span class="text-danger">*</span></label>
                                        <input type="text" class="sdr-auth-input" placeholder="e.g. xyz@google.com"
                                            id="email" name="email">
                                    </div>
                                    <div class="form-group-auth" style="display: flex; align-items: flex-end;">
                                        <input type="submit" name="submit" value="GetOTP"
                                            class="sdr-auth-btn sdr-auth-btn-sm" style="margin-bottom: 0;">
                                    </div>
                                    <div class="form-group-auth">
                                        <label for="otp">Enter OTP <span class="text-danger">*</span></label>
                                        <input type="text" class="sdr-auth-input" placeholder="OTP" id="otp" name="otp">
                                    </div>
                                </div>

                                <!-- Password + Re-type -->
                                <div class="form-row-auth">
                                    <div class="form-group-auth">
                                        <label for="password">Password <span class="text-danger">*</span></label>
                                        <input type="password" class="sdr-auth-input" placeholder="*****" id="password"
                                            name="password">
                                    </div>
                                    <div class="form-group-auth">
                                        <label for="re_password">Re-type Password <span
                                                class="text-danger">*</span></label>
                                        <input type="password" class="sdr-auth-input" placeholder="*****"
                                            id="re_password" name="re_password">
                                    </div>
                                </div>

                                <input type="submit" name="submit" value="update" class="sdr-auth-btn"
                                    style="margin-top: 8px;">

                            </form>
                        </div>
                    </div>
                </div>

                <%- include("../partials/userFooter") %>
                    <%- include("../partials/homeFooter") %>