<%- include("../partials/userHeader") %>

    <body class="">
        <%- include("../partials/loader") %>
            <%- include("../partials/arrownav") %>

                <div class="sdr-auth-wrapper">
                    <div class="sdr-admin-card">
                        <h3><span class="gradient-text">Admin</span> Login</h3>

                        <form id="adminLoginForm" action="/admin" method="post" class="sdr-auth-body" style="padding: 0;">
                            <div class="form-group-auth">
                                <label for="email">Username <span class="text-danger">*</span></label>
                                <input type="text" class="sdr-auth-input" id="email" name="email"
                                    placeholder="Enter username" required>
                            </div>

                            <div class="form-group-auth">
                                <label for="password">Password <span class="text-danger">*</span></label>
                                <input type="password" class="sdr-auth-input" id="password" name="password"
                                    placeholder="Enter password" required>
                            </div>

                            <div class="form-row-auth">
                                <div class="form-group-auth">
                                    <label for="otp">OTP</label>
                                    <input type="text" class="sdr-auth-input" id="otp" name="otp" placeholder="Enter OTP">
                                </div>
                                <div class="form-group-auth" style="display: flex; align-items: flex-end;">
                                    <input type="submit" name="submit" value="GetOTP"
                                        class="sdr-auth-btn sdr-auth-btn-sm" style="margin-bottom: 0;">
                                </div>
                            </div>

                            <input type="submit" name="submit" value="Login" class="sdr-auth-btn"
                                style="margin-top: 12px; width: 100%; justify-content: center;">
                        </form>
                    </div>
                </div>

                <script src="/js/script.js"></script>
                <%- include("../partials/homeFooter") %>
                    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
                    <script src="/js/backNhome.js"></script>
                    <%- include("../partials/footer") %>